// Two Pointers - coppie con somma == target in array ordinato
vector<pair<int,int>> twoSum(vector<int>& a, int target) {
    vector<pair<int,int>> res;
    int lo = 0, hi = a.size()-1;
    while (lo < hi) {
        int s = a[lo]+a[hi];
        if (s == target) { res.push_back({a[lo], a[hi]}); lo++; hi--; }
        else if (s < target) lo++;
        else hi--;
    }
    return res;
}
