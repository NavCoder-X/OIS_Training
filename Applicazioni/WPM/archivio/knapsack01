// Zaino 0/1 - n oggetti, capacita W
// dp[j] = valore massimo con capacita j
int knapsack01(int W, vector<int>& wt, vector<int>& val) {
    int n = wt.size();
    vector<int> dp(W+1, 0);
    for (int i = 0; i < n; i++)
        for (int j = W; j >= wt[i]; j--)
            dp[j] = max(dp[j], dp[j-wt[i]]+val[i]);
    return dp[W];
}
