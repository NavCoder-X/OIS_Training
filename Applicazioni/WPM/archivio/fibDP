// Fibonacci con tabulation
long long fib(int n) {
    if (n <= 1) return n;
    vector<long long> dp(n+1);
    dp[0] = 0; dp[1] = 1;
    for (int i = 2; i <= n; i++)
        dp[i] = dp[i-1]+dp[i-2];
    return dp[n];
}
// con memoization (map)
map<int,long long> memo;
long long fibMemo(int n) {
    if (n <= 1) return n;
    if (memo.count(n)) return memo[n];
    return memo[n] = fibMemo(n-1)+fibMemo(n-2);
}
